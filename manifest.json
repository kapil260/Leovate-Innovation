{
  "manifest_version": 3,
  "name": "Recall AI",
  "version": "3.0.2",
  "description": "AI-powered search history tracker. Captures your prompts across ChatGPT, Gemini, Claude, Perplexity, Copilot, Meta AI & Grok.",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "home-page/Sigup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat*",
        "https://meta.ai/*",
        "https://www.meta.ai/*",
        "https://grok.x.ai/*",
        "https://x.com/i/grok*"
      ],
      "js": ["page-context.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat*",
        "https://meta.ai/*",
        "https://www.meta.ai/*",
        "https://grok.x.ai/*",
        "https://x.com/i/grok*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "alarms",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://leovate-innovation-3.onrender.com*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://www.bing.com/*",
    "https://meta.ai/*",
    "https://www.meta.ai/*",
    "https://grok.x.ai/*",
    "https://x.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dashboard-page/*",
        "history-page/*",
        "login-page/*",
        "home-page/*",
        "setting-page/*",
        "forgot-page/*",
        "onboarding-page/*",
        "subscription-page/*",
        "profile-page/*",
        "icons/*",
        "debug.html",
        "debug.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
